{
  "name": "QuecPayKit",
  "version": "1.1.8-paypal",
  "summary": "Quectel Pay SDK for PayPal integration only.",
  "description": "QuecPayKit provides payment capabilities for PayPal only. This package does not contain or integrate WeChat Pay, Alipay, or any other third-party payment SDKs.",
  "homepage": "http://gitlab.quectel.com:8108/frontend/app/QuecPayKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "QUEC_CI": "cloud-cicd@quectel.com"
  },
  "source": {
    "http": "https://quec-app-log.oss-cn-beijing.aliyuncs.com/sdk/QuecPayKit1784787998.xcframework.zip",
    "type": "zip"
  },
  "platforms": {
    "ios": "14.0"
  },
  "swift_versions": "5.9",
  "default_subspecs": "default",
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64",
    "BUILD_LIBRARY_FOR_DISTRIBUTION" : "YES"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "subspecs": [
    {
      "name": "default",
      "dependencies": {
        "QuecPayKit/common": []
      }
    },
    {
      "name": "common",
      "preserve_paths": "QuecPayKit/**/*.xcframework"
    },
    {
      "name": "paypal",
      "dependencies": {
        "QuecPayKit/common": []
      }
    }
  ],
  "vendored_frameworks": "QuecPayKit/**/*.xcframework"
}
